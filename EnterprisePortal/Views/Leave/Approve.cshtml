@using EnterprisePortal.Models
@{
    ViewData["Title"] = "請假批示";
    var pendingApprovals = ViewBag.PendingApprovals as List<LeaveApprover> ?? new List<LeaveApprover>();
}

<div class="content-card">
    <h4><i class="bi bi-check-circle me-2"></i>請假批示</h4>

    @if (!pendingApprovals.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i>目前沒有待批示的假單。
        </div>
    }
    else
    {
        @foreach (var approver in pendingApprovals)
        {
            var app = approver.LeaveApplication!;
            <div class="card mb-3 border-start border-primary border-4">
                <div class="card-header d-flex justify-content-between align-items-center bg-light">
                    <span>
                        <strong>@app.Applicant?.FullName</strong> (@app.ApplicantId)
                        申請 <span class="badge bg-primary">@app.LeaveType.GetDisplayName()</span>
                    </span>
                    <span class="text-muted small">申請時間：@app.AppliedAt.ToString("yyyy/MM/dd HH:mm")</span>
                </div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <small class="text-muted d-block">請假期間</small>
                            <strong>@app.StartDate.ToString("yyyy/MM/dd") ~ @app.EndDate.ToString("yyyy/MM/dd")</strong>
                            <div class="mt-1 small">
                                <span class="text-muted">起始請假時間：</span>
                                @if (app.StartHour.HasValue)
                                {
                                    <span class="text-primary fw-bold">@app.StartHour.Value.ToString("D2"):00</span>
                                }
                                else
                                {
                                    <span class="text-muted">--:--</span>
                                }
                                <span class="ms-2 text-muted">結束請假時間：</span>
                                @if (app.EndHour.HasValue)
                                {
                                    <span class="text-primary fw-bold">@app.EndHour.Value.ToString("D2"):00</span>
                                }
                                else
                                {
                                    <span class="text-muted">--:--</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-8">
                            <small class="text-muted d-block">請假原因</small>
                            @app.Reason
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(app.AttachmentPath))
                    {
                        <div class="mb-3">
                            <a href="@app.AttachmentPath" target="_blank" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-paperclip me-1"></i>查看附件
                            </a>
                        </div>
                    }

                    <div class="mb-3">
                        <small class="text-muted d-block">簽核流程</small>
                        <div class="d-flex flex-wrap gap-2 mt-1">
                            @foreach (var a in app.Approvers.OrderBy(x => x.ApprovalOrder))
                            {
                                var badgeClass = a.Status == ApprovalStatus.Approved ? "bg-success" :
                                                 a.Status == ApprovalStatus.Rejected ? "bg-danger" : "bg-secondary";
                                var icon = a.Status == ApprovalStatus.Approved ? "bi-check-circle" :
                                           a.Status == ApprovalStatus.Rejected ? "bi-x-circle" : "bi-hourglass";
                                <span class="badge @badgeClass">
                                    <i class="bi @icon me-1"></i>
                                    @(a.ApprovalOrder == 0 ? "代理人" : $"第{a.ApprovalOrder}關") @a.Approver?.FullName
                                </span>
                            }
                        </div>
                    </div>

                    @if (approver.ApprovalOrder == 0)
                    {
                        <div class="alert alert-info py-2 mb-3">
                            <i class="bi bi-person-check me-1"></i>您是此假單的 <strong>代理人</strong>，請確認是否同意由您代理。
                        </div>
                    }

                    <form asp-action="ProcessApproval" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="approverRecordId" value="@approver.Id" />
                        <div class="mb-3">
                            <label class="form-label">簽核意見</label>
                            <textarea name="comment" class="form-control" rows="2" placeholder="請輸入簽核意見（選填）"></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" name="action" value="approve" class="btn btn-success">
                                <i class="bi bi-check-lg me-1"></i>同意
                            </button>
                            <button type="submit" name="action" value="reject" class="btn btn-danger"
                                    onclick="return confirm('確定要拒絕此假單嗎？')">
                                <i class="bi bi-x-lg me-1"></i>拒絕
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
    }
</div>
