@model EnterprisePortal.Models.Employee
@{
    ViewData["Title"] = "新增員工";
}

<div class="content-card">
    <h4><i class="bi bi-person-plus-fill me-2"></i>新增員工</h4>

    <form asp-action="EmployeeCreate" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

        <div class="row mb-4">
            <div class="col-md-3 text-center">
                <img id="photoPreview" src="/img/default-avatar.svg" class="rounded-circle border" width="100" height="100" style="object-fit:cover;" />
                <div class="mt-2">
                    <label class="form-label small">員工大頭照</label>
                    <input type="file" name="photoFile" class="form-control form-control-sm" accept="image/*" onchange="previewPhoto(this)" />
                </div>
            </div>
            <div class="col-md-9">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">員工編號 <span class="text-danger">*</span></label>
                        <input asp-for="EmployeeId" class="form-control" placeholder="例：EMP002" />
                        <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="FullName" class="form-label">姓名 <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EnglishName" class="form-label">英文姓名</label>
                        <input asp-for="EnglishName" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="Gender" class="form-label">性別</label>
                <select asp-for="Gender" asp-items="@ViewBag.GenderList" class="form-select"></select>
            </div>
            <div class="col-md-3">
                <label asp-for="IdNumber" class="form-label">身份證號</label>
                <input asp-for="IdNumber" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="MaritalStatus" class="form-label">婚姻狀況</label>
                <select asp-for="MaritalStatus" asp-items="@ViewBag.MaritalStatusList" class="form-select"></select>
            </div>
            <div class="col-md-3">
                <label asp-for="EducationLevel" class="form-label">最高學歷</label>
                <select asp-for="EducationLevel" asp-items="@ViewBag.EducationLevelList" class="form-select"></select>
            </div>
            <div class="col-12">
                <label asp-for="Address" class="form-label">聯絡地址</label>
                <input asp-for="Address" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Phone" class="form-label">連絡電話</label>
                <input asp-for="Phone" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Mobile" class="form-label">手機號碼</label>
                <input asp-for="Mobile" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Email" class="form-label">電子郵件</label>
                <input asp-for="Email" type="email" class="form-control" />
            </div>
        </div>

        <hr />
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="HireDate" class="form-label">到職日期</label>
                <input asp-for="HireDate" type="date" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="EmploymentStatus" class="form-label">在職狀況</label>
                <select asp-for="EmploymentStatus" asp-items="@ViewBag.EmploymentStatusList" class="form-select"></select>
            </div>
            <div class="col-md-3">
                <label asp-for="DepartmentId" class="form-label">所屬部門</label>
                <select asp-for="DepartmentId" asp-items="@ViewBag.DepartmentList" class="form-select">
                    <option value="">-- 請選擇 --</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="SupervisorId" class="form-label">直屬主管</label>
                <select asp-for="SupervisorId" asp-items="@ViewBag.SupervisorList" class="form-select">
                    <option value="">-- 請選擇 --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="JobTitle" class="form-label">擔任職稱</label>
                <input asp-for="JobTitle" class="form-control" />
            </div>
        </div>

        <hr />
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">初始密碼 <span class="text-danger">*</span></label>
                <input type="password" name="password" class="form-control" placeholder="請設定初始登入密碼" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">確認密碼</label>
                <input type="password" id="confirmPwd" class="form-control" placeholder="再次輸入密碼" />
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-success" onclick="return validatePwd()">
                <i class="bi bi-person-plus me-1"></i>新增員工
            </button>
            <a asp-action="EmployeeList" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>返回列表
            </a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    function previewPhoto(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = e => document.getElementById('photoPreview').src = e.target.result;
            reader.readAsDataURL(input.files[0]);
        }
    }
    function validatePwd() {
        var p1 = document.querySelector('input[name="password"]').value;
        var p2 = document.getElementById('confirmPwd').value;
        if (p2 && p1 !== p2) { alert('兩次密碼輸入不一致！'); return false; }
        return true;
    }
</script>
}
