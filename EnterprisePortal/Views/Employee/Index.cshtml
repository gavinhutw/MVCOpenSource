@{
    ViewData["Title"] = "員工基本資料維護";
}

<div class="content-card" style="max-width:500px;">
    <h4><i class="bi bi-person-gear me-2"></i>員工基本資料維護</h4>
    <p class="text-muted">請輸入要查詢的員工編號，系統將顯示該員工的基本資料供維護。</p>

    <form asp-action="Edit" method="get" class="d-flex gap-2">
        <input type="text" name="id" class="form-control" placeholder="請輸入員工編號" />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search me-1"></i>查詢
        </button>
    </form>

    <hr />
    <div class="text-center">
        <a asp-action="Edit" class="btn btn-outline-primary">
            <i class="bi bi-person-fill me-1"></i>維護我的資料
        </a>
    </div>
</div>
