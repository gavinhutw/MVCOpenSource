@model EnterprisePortal.ViewModels.OvertimeApplicationViewModel
@{
    ViewData["Title"] = "加班申請";
}

<div class="content-card">
    <h4><i class="bi bi-clock-history me-2"></i>加班申請</h4>

    <form asp-action="Apply" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="StartDate" class="form-label">加班起始日期 <span class="text-danger">*</span></label>
                <input asp-for="StartDate" type="date" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="EndDate" class="form-label">加班結束日期 <span class="text-danger">*</span></label>
                <input asp-for="EndDate" type="date" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger small"></span>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-12">
                <label asp-for="Reason" class="form-label">加班原因 <span class="text-danger">*</span></label>
                <textarea asp-for="Reason" class="form-control" rows="3" placeholder="請輸入加班原因..."></textarea>
                <span asp-validation-for="Reason" class="text-danger small"></span>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-6">
                <label asp-for="ProxyId" class="form-label">代理人 <span class="text-danger">*</span></label>
                <select asp-for="ProxyId" asp-items="Model.EmployeeList" class="form-select">
                    <option value="">-- 請選擇代理人 --</option>
                </select>
                <span asp-validation-for="ProxyId" class="text-danger small"></span>
            </div>
        </div>

        <div class="mt-3">
            <label class="form-label fw-bold">簽核主管（依序簽核）<span class="text-danger"> *</span></label>
            <div id="approversContainer">
                <div class="approver-row d-flex align-items-center gap-2">
                    <span class="badge bg-purple me-1" style="background:#7c3aed;">第 1 位</span>
                    <select name="ApproverIds[0]" class="form-select form-select-sm">
                        <option value="">-- 請選擇簽核主管 --</option>
                        @foreach (var item in (Model.EmployeeList ?? new Microsoft.AspNetCore.Mvc.Rendering.SelectList(new List<object>())))
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeApprover(this)" style="display:none;">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
            <button type="button" class="btn btn-sm mt-2 btn-add-approver" style="border: 1px dashed #7c3aed; color:#7c3aed;" onclick="addApprover()">
                <i class="bi bi-plus-circle me-1"></i>新增簽核主管
            </button>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-send me-1"></i>送出加班申請
            </button>
            <a asp-action="Query" class="btn btn-outline-secondary">
                <i class="bi bi-list-ul me-1"></i>查看記錄
            </a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    var employeeOptions = `@Html.Raw(string.Join("", (Model.EmployeeList ?? new Microsoft.AspNetCore.Mvc.Rendering.SelectList(new List<object>()))
        .Select(i => $"<option value='{i.Value}'>{i.Text}</option>")))`;
    var approverCount = 1;

    function addApprover() {
        approverCount++;
        var container = document.getElementById('approversContainer');
        var div = document.createElement('div');
        div.className = 'approver-row d-flex align-items-center gap-2';
        div.innerHTML = `<span class="badge me-1" style="background:#7c3aed;">第 ${approverCount} 位</span>
            <select name="ApproverIds[${approverCount-1}]" class="form-select form-select-sm">
                <option value="">-- 請選擇簽核主管 --</option>
                ${employeeOptions}
            </select>
            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeApprover(this)">
                <i class="bi bi-trash"></i>
            </button>`;
        container.appendChild(div);
        updateBadges();
    }

    function removeApprover(btn) {
        btn.closest('.approver-row').remove();
        updateBadges();
    }

    function updateBadges() {
        var rows = document.querySelectorAll('.approver-row');
        rows.forEach(function(row, i) {
            row.querySelector('.badge').textContent = '第 ' + (i+1) + ' 位';
            row.querySelector('select').name = 'ApproverIds[' + i + ']';
            var delBtn = row.querySelector('button');
            if (delBtn) delBtn.style.display = rows.length > 1 ? '' : 'none';
        });
        approverCount = rows.length;
    }
</script>
}
