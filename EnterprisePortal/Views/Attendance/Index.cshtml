@model EnterprisePortal.ViewModels.AttendanceViewModel
@{
    ViewData["Title"] = "上下班刷卡";
}

<div class="content-card" style="max-width:480px; margin:0 auto;">
    <h4><i class="bi bi-fingerprint me-2"></i>上下班刷卡</h4>

    <div class="text-center mb-4">
        <div class="display-6 fw-bold text-primary" id="clock">--:--:--</div>
        <div class="text-muted" id="dateDisplay">@DateTime.Now.ToString("yyyy年MM月dd日")</div>
    </div>

    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

        <div class="mb-4">
            <label class="form-label fw-bold">刷卡類別 <span class="text-danger">*</span></label>
            <div class="d-flex gap-3">
                <div class="form-check flex-fill">
                    <input class="form-check-input" type="radio" asp-for="ClockType" value="1" id="clockIn" checked />
                    <label class="form-check-label w-100" for="clockIn">
                        <div class="card p-3 text-center clocktype-card" id="cardIn" style="cursor:pointer; border-color: #10b981;">
                            <i class="bi bi-box-arrow-in-right text-success" style="font-size:2rem;"></i>
                            <div class="fw-bold text-success mt-1">上班刷卡</div>
                        </div>
                    </label>
                </div>
                <div class="form-check flex-fill">
                    <input class="form-check-input" type="radio" asp-for="ClockType" value="2" id="clockOut" />
                    <label class="form-check-label w-100" for="clockOut">
                        <div class="card p-3 text-center clocktype-card" id="cardOut" style="cursor:pointer;">
                            <i class="bi bi-box-arrow-right text-danger" style="font-size:2rem;"></i>
                            <div class="fw-bold text-danger mt-1">下班刷卡</div>
                        </div>
                    </label>
                </div>
            </div>
            <span asp-validation-for="ClockType" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Temperature" class="form-label fw-bold">
                <i class="bi bi-thermometer-half me-1"></i>體溫 (℃) <span class="text-danger">*</span>
            </label>
            <div class="input-group">
                <input asp-for="Temperature" type="number" step="0.1" min="35.0" max="42.0"
                       class="form-control form-control-lg" placeholder="例：36.5" />
                <span class="input-group-text">℃</span>
            </div>
            <span asp-validation-for="Temperature" class="text-danger small"></span>
            <div class="form-text">正常體溫範圍：35.0℃ ~ 37.5℃</div>
        </div>

        <div class="d-grid">
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-check-circle me-2"></i>確認刷卡
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    // Live clock
    function updateClock() {
        var now = new Date();
        var h = String(now.getHours()).padStart(2, '0');
        var m = String(now.getMinutes()).padStart(2, '0');
        var s = String(now.getSeconds()).padStart(2, '0');
        document.getElementById('clock').textContent = h + ':' + m + ':' + s;
    }
    setInterval(updateClock, 1000);
    updateClock();

    // Card selection highlight
    document.querySelectorAll('input[name="ClockType"]').forEach(function(radio) {
        radio.addEventListener('change', function() {
            document.getElementById('cardIn').style.borderColor = '';
            document.getElementById('cardOut').style.borderColor = '';
            if (this.value === '1') {
                document.getElementById('cardIn').style.borderColor = '#10b981';
                document.getElementById('cardIn').style.borderWidth = '2px';
                document.getElementById('cardOut').style.borderColor = '';
                document.getElementById('cardOut').style.borderWidth = '';
            } else {
                document.getElementById('cardOut').style.borderColor = '#ef4444';
                document.getElementById('cardOut').style.borderWidth = '2px';
                document.getElementById('cardIn').style.borderColor = '';
                document.getElementById('cardIn').style.borderWidth = '';
            }
        });
    });
</script>
}
